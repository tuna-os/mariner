{
  "id": "org.tunaos.mariner",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "mariner",
  "rename-desktop-file": "com.github.romgrk.mariner.desktop",
  "rename-icon": "com.github.romgrk.mariner",
  "tags": ["latest"],
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=host",
    "--filesystem=home",
    "--talk-name=org.freedesktop.Flatpak",
    "--talk-name=org.gtk.vfs.*",
    "--talk-name=org.gtk.vfs.Daemon",
    "--talk-name=org.gtk.vfs.Notifications",
    "--system-talk-name=org.freedesktop.UDisks2",
    "--env=GIO_EXTRA_MODULES=/app/lib/gio/modules",
    "--own-name=com.github.romgrk.mariner"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/share/doc",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "nodejs",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p /app/nodejs",
        "cp -r . /app/nodejs/",
        "rm -f /app/nodejs/node.tar.xz"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://nodejs.org/dist/v22.23.1/node-v22.23.1-linux-x64.tar.xz",
          "sha256": "9749e988f437343b7fa832c69ded82a312e41a03116d766797ac14f6f9eee578",
          "only-arches": ["x86_64"]
        },
        {
          "type": "archive",
          "url": "https://nodejs.org/dist/v22.23.1/node-v22.23.1-linux-arm64.tar.xz",
          "sha256": "0294e8b915ab75f92c7513d2fcb830ae06e10684e6c603e99a87dbf8835389c1",
          "only-arches": ["aarch64"]
        }
      ]
    },
    {
      "name": "node-headers",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p /app/nodejs-headers",
        "cp -r . /app/nodejs-headers/"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://nodejs.org/dist/v22.23.1/node-v22.23.1-headers.tar.xz",
          "sha256": "b4d28a1c11bf6f643597e09101980904390df9480d835e1f07cc0a20d41768dc"
        }
      ]
    },
    {
      "name": "ripgrep",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 rg /app/bin/rg"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/BurntSushi/ripgrep/releases/download/15.1.0/ripgrep-15.1.0-x86_64-unknown-linux-musl.tar.gz",
          "sha256": "1c9297be4a084eea7ecaedf93eb03d058d6faae29bbc57ecdaf5063921491599",
          "only-arches": ["x86_64"]
        },
        {
          "type": "archive",
          "url": "https://github.com/BurntSushi/ripgrep/releases/download/15.1.0/ripgrep-15.1.0-aarch64-unknown-linux-gnu.tar.gz",
          "sha256": "2b661c6ef508e902f388e9098d9c4c5aca72c87b55922d94abdba830b4dc885e",
          "only-arches": ["aarch64"]
        }
      ]
    },
    {
      "name": "7z",
      "buildsystem": "simple",
      "build-commands": [
        "cp makefile.linux_any_cpu makefile.machine",
        "make -j$(nproc) 7za",
        "install -Dm755 bin/7za /app/bin/7za",
        "ln -s 7za /app/bin/7z"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/p7zip-project/p7zip/archive/refs/tags/v17.05.tar.gz",
          "sha256": "d2788f892571058c08d27095c22154579dfefb807ebe357d145ab2ddddefb1a6"
        }
      ]
    },
    {
      "name": "unrar",
      "buildsystem": "simple",
      "build-commands": [
        "make -j$(nproc) -f makefile",
        "install -Dm755 unrar /app/bin/unrar"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://www.rarlab.com/rar/unrarsrc-7.1.6.tar.gz",
          "sha256": "ca5e1da37dd6fa1b78bb5ed675486413f79e4a917709744aa04b6f93dfd914f0"
        }
      ]
    },
    {
      "name": "mariner",
      "buildsystem": "simple",
      "build-options": {
        "build-args": ["--share=network"],
        "env": {
          "PATH": "/app/nodejs/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
          "npm_config_build_from_source": "true",
          "npm_config_nodedir": "/app/nodejs-headers",
          "npm_config_cache": "/tmp/npm-cache"
        }
      },
      "build-commands": [
        "mkdir -p /app/mariner",
        "cp -r /run/build/mariner/. /app/mariner/",
        "cd /app/mariner && npm install --omit=dev --no-fund --no-audit",
        "rm -rf /app/mariner/node_modules/.cache /tmp/npm-cache",
        "mkdir -p /app/bin",
        "printf '#!/bin/sh\nexec /app/nodejs/bin/node --import /app/mariner/node_modules/node-gtk/lib/esm/register.mjs /app/mariner/src/main.ts \"$@\"\n' > /app/bin/mariner",
        "chmod 755 /app/bin/mariner",
        "printf '%s\\n' '#!/bin/sh' '' '# Terminal wrapper - delegates to host via flatpak-spawn' 'for term in ptyxis kgx gnome-terminal konsole alacritty foot xterm; do' '  if flatpak-spawn --host sh -c \"command -v \\$term\" >/dev/null 2>&1; then' '    exec flatpak-spawn --host \"$term\" \"$@\"' '  fi' 'done' 'exit 1' > /app/bin/ptyxis",
        "chmod 755 /app/bin/ptyxis",
        "printf '%s\\n' '#!/bin/sh' '' '# unar wrapper -> unrar for RAR extraction' 'force=' 'dest=' 'while [ $# -gt 0 ]; do' '  case $1 in' '    -f) force=-o+; shift;;' '    -o) shift; dest=$1; shift;;' '    *) file=$1; shift;;' '  esac' 'done' 'exec /app/bin/unrar x $force \"$file\" \"${dest:-.}\"/' > /app/bin/unar",
        "chmod 755 /app/bin/unar",
        "install -Dm644 /app/mariner/data/com.github.romgrk.mariner.desktop /app/share/applications/com.github.romgrk.mariner.desktop",
        "install -Dm644 /app/mariner/data/com.github.romgrk.mariner.metainfo.xml /app/share/metainfo/com.github.romgrk.mariner.metainfo.xml",
        "install -Dm644 /app/mariner/data/icons/hicolor/scalable/apps/com.github.romgrk.mariner.svg /app/share/icons/hicolor/scalable/apps/com.github.romgrk.mariner.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
