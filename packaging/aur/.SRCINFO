pkgbase = mariner-git
	pkgdesc = A GNOME Files clone built with node-gtk and TypeScript (GTK4 + libadwaita)
	pkgver = 0.0.1.r0.g0000000
	pkgrel = 1
	url = https://github.com/romgrk/mariner
	install = mariner.install
	arch = x86_64
	license = MIT
	makedepends = git
	makedepends = npm
	makedepends = node-gyp
	makedepends = python
	makedepends = pkgconf
	makedepends = gobject-introspection
	makedepends = cairo
	makedepends = glib2
	depends = nodejs>=22.18
	depends = gtk4
	depends = libadwaita
	depends = gobject-introspection-runtime
	depends = gvfs
	optdepends = ripgrep: full-text search inside file contents
	optdepends = unzip: extract .zip and .jar archives
	optdepends = zip: create .zip archives
	optdepends = gvfs-smb: mount Windows/Samba network shares
	optdepends = gvfs-mtp: mount phones and media players
	optdepends = xdg-user-dirs: localized Documents/Downloads/… places in the sidebar
	optdepends = gnome-console: "Open Terminal Here" (or any of ptyxis, konsole, foot, alacritty, xterm)
	provides = mariner
	conflicts = mariner
	source = mariner::git+https://github.com/romgrk/mariner.git
	sha256sums = SKIP

pkgname = mariner-git
