{
  "id": "org.tunaos.mariner",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "mariner",
  "rename-desktop-file": "com.github.romgrk.mariner.desktop",
  "rename-icon": "com.github.romgrk.mariner",
  "tags": ["latest"],
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=host",
    "--filesystem=home",
    "--talk-name=org.freedesktop.Flatpak",
    "--talk-name=org.gtk.vfs.*",
    "--talk-name=org.gtk.vfs.Daemon",
    "--talk-name=org.gtk.vfs.Notifications",
    "--system-talk-name=org.freedesktop.UDisks2",
    "--env=GIO_EXTRA_MODULES=/app/lib/gio/modules"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/share/doc",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "nodejs",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p /app/nodejs",
        "cp -r . /app/nodejs/",
        "rm -f /app/nodejs/node.tar.xz"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://nodejs.org/dist/v22.23.1/node-v22.23.1-linux-x64.tar.xz",
          "sha256": "9749e988f437343b7fa832c69ded82a312e41a03116d766797ac14f6f9eee578",
          "only-arches": ["x86_64"]
        }
      ]
    },
    {
      "name": "node-headers",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p /app/nodejs-headers",
        "cp -r . /app/nodejs-headers/"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://nodejs.org/dist/v22.23.1/node-v22.23.1-headers.tar.xz",
          "sha256": "b4d28a1c11bf6f643597e09101980904390df9480d835e1f07cc0a20d41768dc",
          "only-arches": ["x86_64"]
        }
      ]
    },
    {
      "name": "ripgrep",
      "buildsystem": "simple",
      "build-commands": [
        "tar xzf rg.tar.gz -C /tmp --strip-components=1",
        "install -Dm755 /tmp/rg /app/bin/rg",
        "rm -rf /tmp/rg*"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/BurntSushi/ripgrep/releases/download/15.1.0/ripgrep-15.1.0-x86_64-unknown-linux-musl.tar.gz",
          "sha256": "1c9297be4a084eea7ecaedf93eb03d058d6faae29bbc57ecdaf5063921491599",
          "only-arches": ["x86_64"]
        }
      ]
    },
    {
      "name": "7zip",
      "buildsystem": "simple",
      "build-commands": [
        "tar xJf 7z.tar.xz -C /tmp --strip-components=1",
        "install -Dm755 /tmp/7zz /app/bin/7zz",
        "ln -s 7zz /app/bin/7z",
        "rm -rf /tmp/7zz* /tmp/readme* /tmp/History* /tmp/License* /tmp/MANUAL"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://7-zip.org/a/7z2602-linux-x64.tar.xz",
          "sha256": "41aaba7b1235304ab5aa0624530c67ae829496cd29e875925271efdccc28c03e",
          "only-arches": ["x86_64"]
        }
      ]
    },
    {
      "name": "mariner",
      "buildsystem": "simple",
      "build-options": {
        "build-args": ["--share=network"],
        "env": {
          "PATH": "/app/nodejs/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
          "npm_config_build_from_source": "true",
          "npm_config_nodedir": "/app/nodejs-headers",
          "npm_config_cache": "/tmp/npm-cache"
        }
      },
      "build-commands": [
        "mkdir -p /app/mariner",
        "cp -r /run/build/mariner/. /app/mariner/",
        "cd /app/mariner && npm install --omit=dev --no-fund --no-audit",
        "rm -rf /app/mariner/node_modules/.cache /tmp/npm-cache",
        "mkdir -p /app/bin",
        "printf '#!/bin/sh\nexec /app/nodejs/bin/node --import /app/mariner/node_modules/node-gtk/lib/esm/register.mjs /app/mariner/src/main.ts \"$@\"\n' > /app/bin/mariner",
        "chmod 755 /app/bin/mariner",
        "install -Dm644 /app/mariner/data/com.github.romgrk.mariner.desktop /app/share/applications/com.github.romgrk.mariner.desktop",
        "install -Dm644 /app/mariner/data/com.github.romgrk.mariner.metainfo.xml /app/share/metainfo/com.github.romgrk.mariner.metainfo.xml",
        "install -Dm644 /app/mariner/data/icons/hicolor/scalable/apps/com.github.romgrk.mariner.svg /app/share/icons/hicolor/scalable/apps/com.github.romgrk.mariner.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
